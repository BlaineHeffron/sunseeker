---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { Image } from 'astro:assets';
import { GITHUB_URL } from '../consts';
import appStoreHeroImage from '../assets/infographics/solaraim-app-store-hero-background.jpg';
import releaseImage from '../assets/solaraim-mobile-app-release-update.jpg';

const title = 'SolarAim Release Updates';
const description = 'SolarAim mobile app availability and release updates.';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={releaseImage}
      imageAlt="SolarAim mobile app release update illustration for iOS and Android"
    />
  </head>
  <body>
    <Header />
    <main class="download-page">
      <section class="hero">
        <h1>SolarAim Release Updates</h1>
        <p>
          SolarAim mobile apps are in release preparation. Use the links below to track availability.
        </p>
        <Image
          src={releaseImage}
          alt="SolarAim mobile app release update illustration showing iOS and Android availability"
          width={900}
          height={502}
          format="webp"
          quality={82}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          sizes="(max-width: 768px) 100vw, 900px"
          class="release-image"
        />
      </section>

      <section class="store-preview" aria-labelledby="store-preview-heading">
        <div>
          <h2 id="store-preview-heading">Built for quick field checks</h2>
          <p>
            The release build uses the same phone-flat-on-panel workflow shown throughout the site:
            calculate the target, match tilt and direction, then save the reading.
          </p>
        </div>
        <Image
          src={appStoreHeroImage}
          alt="SolarAim app store preview showing phone-based solar panel positioning guidance"
          width={384}
          height={688}
          format="webp"
          quality={80}
          loading="lazy"
          decoding="async"
          sizes="(max-width: 768px) 100vw, 384px"
          class="store-preview-image"
        />
      </section>

      <section class="cards">
        <article class="card" id="ios">
          <h2>iOS</h2>
          <p>The App Store listing will be published here once review is complete.</p>
          <a class="btn btn-primary" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">
            Get Release Updates
          </a>
        </article>
        <article class="card" id="android">
          <h2>Android</h2>
          <p>The Google Play listing will be published here once rollout is complete.</p>
          <a class="btn btn-primary" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">
            Get Release Updates
          </a>
        </article>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .download-page {
    max-width: 900px;
    margin: 0 auto;
  }

  .hero {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .hero p {
    color: var(--text-muted);
    max-width: 680px;
    margin: 0 auto;
  }

  .release-image {
    display: block;
    width: min(100%, 760px);
    margin: 2rem auto 0;
    border: 1px solid var(--warm-gray);
    box-shadow: var(--box-shadow);
  }

  .store-preview {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: 2rem;
    align-items: center;
    padding: 2rem 0;
  }

  .store-preview h2 {
    margin-bottom: 0.75rem;
  }

  .store-preview p {
    color: var(--text-muted);
  }

  .store-preview-image {
    width: min(100%, 384px);
    justify-self: center;
    border: 1px solid var(--warm-gray);
    box-shadow: var(--box-shadow);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
    padding: 1rem 0 2rem;
  }

  .cards .card h2 {
    margin-bottom: 0.75rem;
  }

  .cards .card p {
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  @media (max-width: 768px) {
    .store-preview {
      grid-template-columns: 1fr;
    }

    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
